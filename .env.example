# obdmonai — environment variables
# Copy to .env and fill in real values. Never commit .env.
#
# PORT NOTE: localhost dev ports are offset from icumonai/energymonai to allow
# running stacks side-by-side without conflicts:
#   MQTT  8884  (icumonai uses 8883)
#   API   8002  (icumonai uses 8000)
#   PG    5434  (icumonai uses 5432/5433)
#   Mailhog SMTP 1027 / Web 8027  (icumonai uses 1025/8025)

# --- PostgreSQL / TimescaleDB ---
POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_DB=obdmonai
POSTGRES_USER=obdmonai_app          # non-superuser app role
POSTGRES_PASSWORD=change_me_db_password
POSTGRES_SUPERUSER=postgres
POSTGRES_SUPERUSER_PASSWORD=change_me_superuser_password

# --- pgbouncer ---
PGBOUNCER_POOL_MODE=transaction
PGBOUNCER_MAX_CLIENT_CONN=200

# --- JWT / Auth ---
JWT_SECRET_KEY=change_me_at_least_32_random_chars
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# --- MQTT (Mosquitto) ---
MQTT_HOST=mosquitto
MQTT_PORT=8883                      # internal container port (always 8883)
DEV_MQTT_PORT=8884                  # host-side dev port (avoids 8883 used by sibling stacks)
DEV_PG_PORT=5434                    # host-side Postgres dev port
DEV_API_PORT=8002                   # host-side API dev port
DEV_MAILHOG_SMTP=1027
DEV_MAILHOG_WEB=8027
DEV_FLEETVIEW_PORT=8020
DEV_FRONTEND_PORT=3000
MQTT_CA_CERT=/mosquitto/certs/ca.crt       # dev: mounted from ./infra/mosquitto/certs/
MQTT_CLIENT_CERT=/mosquitto/certs/ingest.crt
MQTT_CLIENT_KEY=/mosquitto/certs/ingest.key

# --- Tier A Notifications (leave blank to disable) ---
SMTP_HOST=                              # e.g. smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=alerts@example.com
SMTP_TO=                                # comma-separated addresses
WEBHOOK_URL=                            # e.g. https://hooks.slack.com/services/...

# --- Anthropic (FleetView) ---
ANTHROPIC_API_KEY=sk-ant-change_me
ANTHROPIC_MODEL=claude-sonnet-4-6

# --- Caddy ---
CADDY_DOMAIN=obdmonai.example.com
CADDY_EMAIL=admin@example.com

# --- App ---
LOG_LEVEL=INFO
ENVIRONMENT=development
